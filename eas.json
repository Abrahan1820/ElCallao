{
  "cli": {
    "version": ">= 15.0.14",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {},
      "ios": {}
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"  
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "apk"  
      },
      "ios": {
        "enterpriseProvisioning": "universal"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./keys/google-play-key.json",
        "track": "production"
      },
      "ios": {
        "appleId": "tu-email@example.com",
        "ascAppId": "123456789"
      }
    }
  }
}