{
  "expo": {
    "name": "GestionNueveOnce",
    "slug": "gestion-nueve-once",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/Icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nueveonce.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/AdaptativeIcon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.nueveonce.app"
    },
    "web": {
      "favicon": "./assets/Icon.png",
      "bundler": "webpack",
      "build": {
        "babel": {
          "include": ["react-native-web"]
        }
    }},
    "extra": {
      "eas": {
        "projectId": "ee939501-5891-430d-9c6d-5d2d0875dbb7"
      }
    }
  }
}