{
  "expo": {
    "name": "ElCallao",
    "slug": "kioskoElCallao",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/Icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kioskoelcallao.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/AdaptativeIcon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.kioskoElCallao.app"
    },
    "web": {
      "favicon": "./assets/Icon.png",
      "bundler": "webpack",
      "build": {
        "babel": {
          "include": [
            "react-native-web"
          ]
        }
      }
    },
    "extra": {
      "eas": {
        "projectId": "1fc1cc99-6653-4407-aeef-0d92cd68136e"
      }
    }
  }
}
